---
const { entry } = Astro.props as { entry: any };
---
<a href={`/${entry.id}/`} class="card-link bg-white rounded-xl border-2 border-accent/20 p-5 hover:border-accent transition-all">
  <span class="text-xs font-bold text-accent uppercase">{entry.data.category}</span>
  <h3 class="font-heading text-xl mt-2">{entry.data.title}</h3>
  <p class="text-sm text-muted mt-1">{entry.data.description}</p>
</a>