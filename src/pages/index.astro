---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
const entries = await getCollection('articles');
---
<BaseLayout title="EngTu Lab" description="英语学习 AI 工具横评（多邻国/流利说/Cambly/italki/AI 口语机器人）">
  <section class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="font-heading text-4xl text-primary leading-tight">EngTu Lab</h1>
    <p class="text-lg text-muted mt-4">英语学习 AI 工具横评（多邻国/流利说/Cambly/italki/AI 口语机器人）</p>
    <div class="mt-12">{entries.map((entry) => <ArticleCard entry={entry} />)}</div>
  </section>
</BaseLayout>